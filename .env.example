# ══════════════════════════════════════════════════════════════
# Olinora — Sistema de Gestión de Turnos
# ══════════════════════════════════════════════════════════════
# Copia este archivo como .env y configura los valores.
# Las variables marcadas con (REQUIRED) son obligatorias.
# Las marcadas con (OPTIONAL) tienen valores por defecto funcionales.
# ══════════════════════════════════════════════════════════════

# ── App ──
APP_NAME=Olinora
APP_ENV=local                          # local | production
APP_KEY=                               # (REQUIRED) php artisan key:generate
APP_DEBUG=true                         # false en producción
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000          # https://olinora.com.mx en producción

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# ── Logging ──
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                        # warning en producción

# ── Database (PostgreSQL) ──
DB_CONNECTION=pgsql                    # (REQUIRED)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=turnos_app                 # (REQUIRED) crear con: createdb turnos_app
DB_USERNAME=turnos_user                # (REQUIRED)
DB_PASSWORD=                           # (REQUIRED)

# ── Session ──
SESSION_DRIVER=redis                   # redis recomendado para producción
SESSION_LIFETIME=120
SESSION_ENCRYPT=true                   # true recomendado para seguridad
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Cache & Queue ──
CACHE_STORE=redis
QUEUE_CONNECTION=redis
FILESYSTEM_DISK=local

# ── Redis ──
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Email ──
MAIL_MAILER=log                        # 'resend' en producción
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@olinora.com.mx"
MAIL_FROM_NAME="${APP_NAME}"

# Para producción con Resend:
# MAIL_MAILER=resend
# RESEND_API_KEY=re_xxxxxxxxxxxx

# ── Encryption (CipherSweet) ──
# (REQUIRED) Cifrado de datos personales (email, phone, IP)
# Generar con: php artisan ciphersweet:generate-key
# IMPORTANTE: Usar key diferente en producción vs desarrollo
CIPHERSWEET_KEY=

# ── WebSockets (Laravel Reverb) ──
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=000000
REVERB_APP_KEY=your-reverb-app-key
REVERB_APP_SECRET=your-reverb-app-secret
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http                     # https en producción

REVERB_ALLOWED_ORIGINS=http://localhost:8000
REVERB_APP_RATE_LIMITING_ENABLED=true
REVERB_APP_RATE_LIMIT_MAX_ATTEMPTS=60
REVERB_APP_RATE_LIMIT_DECAY_SECONDS=60

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
VITE_APP_NAME="${APP_NAME}"

# ── OAuth: Google (OPTIONAL) ──
# Configurar en https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${APP_URL}/auth/google/callback

# ── OAuth: Facebook (OPTIONAL — actualmente deshabilitado en UI) ──
# Backend funcional pero botones comentados en SocialAuthButtons.jsx
# Para reactivar: descomentar botones + completar verificación en Meta
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=${APP_URL}/auth/facebook/callback

# ── Monitoring: Telegram (OPTIONAL) ──
# Bot para alertas del sistema, reportes semanales, notificaciones de deploy
# Crear bot con @BotFather, obtener chat_id con @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERTS_ENABLED=false          # true en producción

# ── External APIs (OPTIONAL) ──
# OpenWeatherMap — clima en pantallas de display
# Registrar en https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=

# GeoNames — selects cascada país→estado→ciudad en onboarding
# Registrar en https://www.geonames.org/login
GEONAMES_USERNAME=

# ── Billing (Stripe / Mercado Pago / etc.) ──
# Ver docs/billing/SECRETS.md para guía operativa completa.
# Activación de pagos planificada en Fase 2 (Stripe primero).

BILLING_DEFAULT_GATEWAY=stripe         # stripe | mercadopago | manual

# Stripe — modo activo. Solo se llenan las keys del modo activo.
# En desarrollo: STRIPE_MODE=test  + variables STRIPE_TEST_*
# En producción: STRIPE_MODE=live  + variables STRIPE_LIVE_*
STRIPE_ENABLED=true
STRIPE_MODE=test                       # test | live

# Stripe TEST mode (desarrollo). Obtener en:
# https://dashboard.stripe.com/test/apikeys
STRIPE_TEST_PUBLIC_KEY=                # pk_test_*
STRIPE_TEST_SECRET_KEY=                # sk_test_*
STRIPE_TEST_WEBHOOK_SECRET=            # whsec_* (uno por endpoint, ver SECRETS.md)

# Stripe LIVE mode (producción). Obtener en:
# https://dashboard.stripe.com/apikeys (con test toggle apagado)
STRIPE_LIVE_PUBLIC_KEY=                # pk_live_*
STRIPE_LIVE_SECRET_KEY=                # sk_live_*
STRIPE_LIVE_WEBHOOK_SECRET=            # whsec_*

# Webhooks (gateway-agnostic, OPTIONAL)
BILLING_WEBHOOK_TOLERANCE=300          # segundos, ventana anti-replay
BILLING_WEBHOOK_IDEMPOTENCY_HOURS=24
BILLING_WEBHOOK_RETRY_MAX=5

# Otras pasarelas (deferred — ver docs/billing/BACKLOG.md)
MERCADOPAGO_ENABLED=false              # Fase 4
OPENPAY_ENABLED=false                  # backlog
CONEKTA_ENABLED=false                  # backlog
PAYPAL_ENABLED=false                   # backlog
MANUAL_GATEWAY_ENABLED=true            # transferencia / pago offline

# ── Seeder de producción (OPTIONAL) ──
# Datos del tenant piloto que se crea con php artisan db:seed
# Solo necesario para el primer deploy
# PILOT_TENANT_NAME="Mi Empresa"
# PILOT_ADMIN_NAME="Administrador"
# PILOT_ADMIN_EMAIL="admin@empresa.com"
# PILOT_ADMIN_PASSWORD="password-seguro"

# ── AWS (no usado actualmente) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

MEMCACHED_HOST=127.0.0.1
